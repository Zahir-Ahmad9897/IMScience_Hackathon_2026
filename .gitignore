# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# --- Virtual Environments ---
venv/
myvenv/
.venv/
env/
ENV/

# --- Environment & Secrets (NEVER commit) ---
.env
.env.*
*.env
secrets.json

# --- Database ---
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
database.db

# --- Streamlit ---
.streamlit/secrets.toml

# --- LangSmith / LangChain ---
.langchain/
langchain_cache/

# --- IDE ---
.vscode/
.idea/
*.code-workspace
*.swp
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs & temp ---
*.log
*.tmp
logs/
tmp/

# --- Audio / TTS ---
*.mp3
*.wav
*.ogg

# --- Test scripts (contain credentials) ---
test_email.py

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb


